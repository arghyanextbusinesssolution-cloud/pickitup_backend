// =====================
// 3. SHIPMENT MARKETPLACE
// =====================

model Shipment {
  id                   String         @id @default(cuid())
  title                String
  description          String?

  ownerId              String
  owner                User           @relation("UserShipments", fields: [ownerId], references: [id], onDelete: Restrict)

  status               ShipmentStatus @default(OPEN)

  // =====================
  // 📍 ORIGIN (UPDATED)
  // =====================
  originAddress        String
  originLatitude       Float
  originLongitude      Float
  originPlaceId        String?   

  originCity           String?   
  originState          String?   
  originCountry        String?   
  originPostalCode     String?   

  // =====================
  // 📍 DESTINATION (UPDATED)
  // =====================
  destinationAddress   String
  destinationLatitude  Float
  destinationLongitude Float
  destinationPlaceId   String?   

  destinationCity      String?   
  destinationState     String?   
  destinationCountry   String?   
  destinationPostalCode String?  

  // =====================
  // 🚚 DISTANCE (KEEP)
  // =====================
  distanceKm           Float?
  estimatedTimeMin     Int?

  // =====================
  // 📦 SHIPMENT DETAILS (IMPROVED)
  // =====================
  category             String?   

  weight               Float?
  weightUnit           String @default("kg")  

  length               Float?   
  width                Float?   
  height               Float?   
  dimensionUnit        String @default("cm")  

  // =====================
  // 📅 DATES (IMPROVED)
  // =====================
  pickupDate           DateTime?
  deliveryDate         DateTime?

  isFlexiblePickup     Boolean @default(false)   
  isFlexibleDelivery   Boolean @default(false)   

  // =====================
  // 💰 PRICING (IMPROVED)
  // =====================
  budgetMin            Decimal? @db.Decimal(12, 2)  
  budgetMax            Decimal? @db.Decimal(12, 2)  

  estimatedPrice       Decimal? @db.Decimal(12, 2)
  finalPrice           Decimal? @db.Decimal(12, 2)

  // =====================
  // 🚪 LOGISTICS (NEW)
  // =====================
  pickupType           LocationType @default(RESIDENTIAL)   
  deliveryType         LocationType @default(RESIDENTIAL)   

  pickupNotes          String?   
  deliveryNotes        String?   

  hasElevatorPickup    Boolean?  
  hasElevatorDelivery  Boolean?  

  pickupFloor          Int?      
  deliveryFloor        Int?      

  // =====================
  // 🧾 EXTRA (OPTIONAL BUT GOOD)
  // =====================
  specialRequirements  String?   
  isPalletized         Boolean @default(false)  
  isCrated             Boolean @default(false)  

  // =====================
  // SYSTEM
  // =====================
  deletedAt            DateTime?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  // =====================
  // RELATIONS (KEEP)
  // =====================
  items         ShipmentItem[]
  images        ShipmentImage[]
  bids          Bid[]
  booking       Booking?
  conversations Conversation[]
  reviews       Review[]
  stops         ShipmentStop[]
  documents     ShipmentDocument[]

  @@index([ownerId])
  @@index([status])
  @@index([createdAt])
  @@index([status, createdAt])        
  @@index([originLatitude, originLongitude])   
  @@index([destinationLatitude, destinationLongitude]) 
}

model ShipmentItem {
  id         String   @id @default(cuid())
  shipmentId String
  shipment   Shipment @relation(fields: [shipmentId], references: [id], onDelete: Cascade)
  name       String
  quantity   Int      @default(1)
  weight     Float?
  dimensions String?

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  deletedAt  DateTime?

  @@index([shipmentId])
}

model ShipmentImage {
  id         String   @id @default(cuid())
  shipmentId String
  shipment   Shipment @relation(fields: [shipmentId], references: [id], onDelete: Cascade)
  imageUrl   String
  fileSize   Int?               
  mimeType   String?            
  uploadedBy String?            
  uploadedAt DateTime @default(now())
  updatedAt  DateTime @updatedAt
  deletedAt  DateTime?

  @@index([shipmentId])
}

model ShipmentStop {
  id         String   @id @default(cuid())
  shipmentId String
  shipment   Shipment @relation(fields: [shipmentId], references: [id], onDelete: Cascade)
  address    String
  latitude   Float
  longitude  Float
  placeId    String?  // Google Places ID
  stopOrder  Int      @default(1)
  stopType   StopType @default(PICKUP)
  
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  deletedAt  DateTime?

  @@index([shipmentId])
}

enum StopType {
  PICKUP
  DELIVERY
  REST_STOP
}

model ShipmentDocument {
  id           String   @id @default(cuid())
  shipmentId   String
  shipment     Shipment @relation(fields: [shipmentId], references: [id], onDelete: Cascade)
  documentType String
  fileUrl      String
  
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  deletedAt    DateTime?

  @@index([shipmentId])
}

enum ShipmentStatus {
  OPEN
  ASSIGNED
  IN_TRANSIT
  DELIVERED
  CANCELLED
}

enum LocationType {
  RESIDENTIAL
  BUSINESS
  WAREHOUSE
  PORT
}

