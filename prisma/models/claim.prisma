// =====================
// 11. INSURANCE CLAIM MANAGEMENT
// =====================

model Claim {
  id         String        @id @default(cuid())
  bookingId  String
  booking    Booking       @relation(fields: [bookingId], references: [id], onDelete: Restrict)
  raisedById String
  raisedBy   User          @relation(fields: [raisedById], references: [id], onDelete: Restrict)
  reason     String
  status     ClaimStatus @default(OPEN)
  
  messages   ClaimMessage[]
  attachments ClaimAttachment[]

  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt
  deletedAt  DateTime?

  @@index([bookingId])
  @@index([raisedById])
  @@index([status])
  @@map("Dispute")
}

enum ClaimStatus {
  OPEN
  UNDER_REVIEW
  RESOLVED
  CLOSED
  @@map("DisputeStatus")
}

model ClaimMessage {
  id        String   @id @default(cuid())
  claimId   String
  claim     Claim    @relation(fields: [claimId], references: [id], onDelete: Cascade)
  senderId  String
  sender    User     @relation(fields: [senderId], references: [id], onDelete: Restrict)
  message   String
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?

  @@index([claimId, createdAt]) 
  @@index([senderId])
  @@map("DisputeMessage")
}

model ClaimAttachment {
  id          String   @id @default(cuid())
  claimId     String
  claim       Claim    @relation(fields: [claimId], references: [id], onDelete: Cascade)
  fileUrl     String
  fileName    String?
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  deletedAt   DateTime?

  @@index([claimId])
  @@map("DisputeAttachment")
}
